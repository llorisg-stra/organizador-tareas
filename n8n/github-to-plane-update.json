        "jsCode": "const data = $input.first().json.body || $input.first().json;\nconst title = data.pull_request.title || '';\nconst action = data.action || '';\nconst merged = data.pull_request.merged || false;\nconst prUrl = data.pull_request.html_url || '';\nconst author = data.pull_request.user ? data.pull_request.user.login : 'unknown';\nconst match = title.match(/SLABS-(\\d+)/i);\nif (!match) { return [{json: {skip: true, reason: 'No SLABS-XX found'}}]; }\nlet targetState = '';\nlet emoji = '';\nlet statusText = '';\nif (action === 'opened' || action === 'reopened') {\n  targetState = 'f4397648-02c5-463f-b113-468943c84bfc';\n  emoji = '🚀';\n  statusText = 'In Progress';\n} else if (action === 'closed' && merged) {\n  targetState = '19806a67-b62f-43b5-b860-7bf4a19e2ce2';\n  emoji = '✅';\n  statusText = 'Done';\n} else if (action === 'closed' && !merged) {\n  targetState = 'd5ba1fc8-8502-404b-a437-92469a63a5d3';\n  emoji = '❌';\n  statusText = 'Backlog';\n} else {\n  return [{json: {skip: true, reason: 'Unknown action'}}];\n}\nreturn [{json: {skip: false, issueSequence: match[1], targetState: targetState, prUrl: prUrl, emoji: emoji, statusText: statusText, author: author, title: title, action: action}}];"
      },
