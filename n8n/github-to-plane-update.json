        "jsCode": "const results = $input.first().json.results || [];\nconst seqId = parseInt($('Code').first().json.issueSequence);\nconst targetState = $('Code').first().json.targetState;\nconst prUrl = $('Code').first().json.prUrl;\nconst issue = results.find(i => i.sequence_id === seqId);\nif (!issue) {\n  return [{ json: { skip: true, reason: 'Issue SLABS-' + seqId + ' not found' } }];\n}\nreturn [{ json: { issueId: issue.id, targetState: targetState, prUrl: prUrl, currentName: issue.name } }];"
